# Base URL of the sync Worker (see worker/). Leave unset to disable cross-device sync entirely --
# the app then runs fully local, exactly as before. This is a public value (baked into the bundle),
# not a secret. Copy this file to .env.local and fill it in to try sync against a local `wrangler dev`
# or your deployed Worker.
# VITE_SYNC_URL=https://questline-sync.<your-subdomain>.workers.dev
